# OLLAMA_BASE_URL: URL of your local Ollama server.
# Default is usually http://127.0.0.1:11434
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# OLLAMA_MODEL: Local model used by the app for AI features.
# Example: llama3.2, mistral, qwen2.5
OLLAMA_MODEL="llama3.2"

# JWT_SECRET: Secret used to sign auth tokens.
JWT_SECRET=""
